{
  "name": "yauzl-promise",
  "version": "3.0.0",
  "description": "Unzip library for NodeJS",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/**/*",
    "index.js"
  ],
  "author": {
    "name": "Overlook Motel"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/overlookmotel/yauzl-promise.git"
  },
  "bugs": {
    "url": "https://github.com/overlookmotel/yauzl-promise/issues"
  },
  "dependencies": {
    "@node-rs/crc32": "^1.7.0",
    "is-it-type": "^5.1.2",
    "simple-invariant": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "bl": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-n": "^17.24.0",
    "jest": "^30.3.0",
    "jest-extended": "^7.0.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "keywords": [
    "yauzl",
    "unzip",
    "zip",
    "archive"
  ],
  "scripts": {
    "test": "npm run lint && npm run test-main",
    "lint": "eslint .",
    "lint-fix": "eslint . --fix",
    "test-main": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest",
    "cover": "npm-run-all -c cover-main cover-cleanup",
    "cover-main": "jest --coverage",
    "cover-cleanup": "rm -rf coverage"
  },
  "engines": {
    "node": ">=16"
  },
  "readmeFilename": "README.md",
  "license": "MIT"
}
